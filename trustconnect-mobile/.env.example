# API Configuration
# ==========================================
# IMPORTANT: Choose the correct URL based on your setup

# Option 1: Android Emulator (AVD)
# Use 10.0.2.2 which maps to your computer's localhost
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000/api

# Option 2: iOS Simulator
# Localhost works fine on iOS
# EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Option 3: Physical Device (Android or iOS)
# Find your computer's IP address:
# - Windows: Run 'ipconfig' and look for IPv4 Address (e.g., 192.168.1.100)
# - Mac/Linux: Run 'ifconfig' or 'ip addr' and look for inet address
# Then replace with your IP:
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3000/api

# Option 4: Production
# EXPO_PUBLIC_API_URL=https://api.trustconnect.ng/api

# ==========================================
# HOW TO FIND YOUR IP ADDRESS:
# Windows: ipconfig
# Mac: ifconfig | grep "inet " | grep -v 127.0.0.1
# Linux: ip addr show
# ==========================================
